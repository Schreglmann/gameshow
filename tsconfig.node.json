    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "outDir": "./dist/node"
  },
  "include": [
    "vite.config.shared.ts",
    "vite.config.frontend.ts",
    "vite.config.admin.ts",
    "vite.config.gamemaster.ts",
    "vite.config.dev.ts"
  ]
}
