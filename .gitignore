# Dependencies
node_modules

.DS_Store

# Build output
dist

# Media folders (raw — decrypted locally, not committed)
audio-guess/
audio-guess
audio/
audio
background-music/
background-music
images/
images

# Encrypted media archives ARE committed (<folder>.tar.gz.enc)
!*.tar.gz.enc

# Temp archives
*.tar.gz

# Ignore decrypted archives (if accidentally created in the root)
*.tar.gz.enc

# Screenshots
*.png
*.jpg
*.jpeg

# Allow documentation screenshots
!docs/screenshots/*.png

.playwright-mcp/
playwright-report/
test-results

local-assets

.vscode

# Local theme preferences (per-device, not committed)
theme-settings.json

# Operator-configurable NAS sync settings — machine-specific NAS path + on/off
# toggle. No sidecar → the default path is used (see specs/nas-sync-config.md).
nas-sync-prefs.json

# Backup of an encrypted config.json that the server replaced with a default
# on startup (see specs/clean-install.md) — raw git-crypt blob, never committed
config.json.git-crypt.bak

# Generated example games ("Beispiele") — produced on demand by the admin button
# or `npm run fixtures` from code fixtures; ephemeral, never committed.
# See specs/example-games.md.
games/beispiel-*.json

.tmp
scheduled_tasks.lock
.tmp-validate
.tmp-claude

# Persistent spellcheck response cache (server/spellcheck.ts) — derived data, ephemeral
.spellcheck-cache.json
.spellcheck-cache.json.tmp

.gitignored-notes
