# Dependencies
node_modules

.DS_Store

# Build output
dist

# Media folders (raw — decrypted locally, not committed)
audio-guess/
audio-guess
audio/
audio
background-music/
background-music
images/
images

# Encrypted media archives ARE committed (<folder>.tar.gz.enc)
!*.tar.gz.enc

# Temp archives
*.tar.gz

# Ignore decrypted archives (if accidentally created in the root)
*.tar.gz.enc

# Screenshots
*.png
*.jpg
*.jpeg

# Allow documentation screenshots
!docs/screenshots/*.png

.playwright-mcp/
playwright-report/
test-results

local-assets

.vscode

# Local theme preferences (per-device, not committed)
theme-settings.json

# Backup of an encrypted config.json that the server replaced with a default
# on startup (see specs/clean-install.md) — raw git-crypt blob, never committed
config.json.git-crypt.bak

.tmp
scheduled_tasks.lock
.tmp-validate
.tmp-claude
