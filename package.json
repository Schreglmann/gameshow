{
  "name": "gameshow",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --config vite.config.dev.ts",
    "dev:server": "cross-env UV_THREADPOOL_SIZE=32 tsx watch server/index.ts",
    "build:client:frontend": "vite build --config vite.config.frontend.ts",
    "build:client:admin": "vite build --config vite.config.admin.ts",
    "build:client:gamemaster": "vite build --config vite.config.gamemaster.ts",
    "build:client": "npm run build:client:frontend && npm run build:client:admin && npm run build:client:gamemaster",
    "build": "tsc -b && tsc -p tsconfig.server.json && npm run build:client",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.cjs",
    "start": "cross-env UV_THREADPOOL_SIZE=32 node dist/server/server/index.js",
    "postinstall": "node scripts/postinstall-hint.cjs",
    "validate": "tsx validate-config.ts",
    "validate-assets": "tsx validate-assets.ts",
    "fixtures": "tsx scripts/create-examples.ts",
    "normalize-audio": "tsx normalize-audio.ts",
    "media:encrypt": "tsx media-crypt.ts encrypt",
    "media:decrypt": "tsx media-crypt.ts decrypt",
    "sync:pull": "tsx sync-assets.ts pull",
    "sync": "tsx sync-assets.ts sync",
    "diagnose:sync": "tsx scripts/diagnose-sync-drift.ts",
    "push:drifted": "tsx scripts/push-drifted-to-nas.ts",
    "backup": "tsx backup-assets.ts",
    "fetch-movie-posters": "tsx fetch-movie-posters.ts",
    "whisper:install": "bash scripts/whisper-install.sh",
    "whisper:download-model": "tsx scripts/whisper-download-model.ts",
    "upscaler:install": "tsx scripts/install-upscaler.ts",
    "generate:hp-spells": "tsx generate-hp-spells.ts",
    "bandle-sync": "node scripts/bandle-sync.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:contracts": "vitest run tests/contracts",
    "test:related": "vitest related --run",
    "test:e2e": "npx playwright test",
    "test:coverage": "vitest run --coverage",
    "contracts:lint": "npx @redocly/cli lint --config specs/api/redocly.yaml specs/api/openapi.yaml && npx @asyncapi/cli validate specs/api/asyncapi.yaml"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/ffprobe-static": "^2.0.3",
    "canvas-confetti": "^1.9.3",
    "express": "^5.2.1",
    "ffmpeg": "^0.0.4",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^1.4.5-lts.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.6.4",
    "@types/express": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "ffprobe-static": "^3.1.0",
    "happy-dom": "^20.7.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
